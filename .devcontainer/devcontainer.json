{
  "name": "Scrutineer",

  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "VARIANT": "1-1.23-bookworm"
    }
  },

  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": true,
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
      "version": "latest",
      "helm": "none",
      "minikube": "none"
    },
    "ghcr.io/devcontainers-extra/features/kind:1": {
      "version": "latest"
    }
  },

  "runArgs": ["--init"],

  "containerEnv": {
    "KIND_CLUSTER_NAME": "scrutineer-dev",
    "SCRUTINEER_DEVCONTAINER": "1"
  },

  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/home/vscode/go/bin:/workspaces/${localWorkspaceFolderBasename}/bin"
  },

  "postCreateCommand": "bash .devcontainer/bootstrap.sh",

  "remoteUser": "vscode",

  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "redhat.vscode-yaml",
        "tamasfe.even-better-toml"
      ],
      "settings": {
        "go.toolsManagement.checkForUpdates": "local",
        "go.useLanguageServer": true,
        "go.gopath": "/home/vscode/go",
        "[go]": {
          "editor.formatOnSave": true,
          "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
          }
        }
      }
    }
  }
}
